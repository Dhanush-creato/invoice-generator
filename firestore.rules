rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile settings (including organization settings)
    match /users/{userId} {
      allow get: if true;
      allow list, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Predefined items list
    // list: allow query for authenticated users (WHERE clause filters by userId in code)
    // get: only owner can fetch a single item
    // create: must include matching userId
    // update, delete: only owner can modify
    match /predefined_items/{itemId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Predefined dealers list
    match /predefined_dealers/{dealerId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Invoices
    match /invoices/{invoiceId} {
      // Anyone can read a single invoice by its exact document ID (for QR code scan to PDF)
      allow get: if true;
      
      // Querying/listing invoices requires authentication
      allow list: if request.auth != null;
      
      // Writing (create, update, delete) requires ownership
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
