rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      // Anyone can read (so public invoices can display logos and signatures)
      allow read: if true;
      // Only the authenticated owner can write files
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /invoices/{invoiceId} {
      // Anyone can read (so public QR code scans can download the PDF file directly)
      allow read: if true;
      // Only authenticated users can save invoice PDFs
      allow write: if request.auth != null;
    }
  }
}
